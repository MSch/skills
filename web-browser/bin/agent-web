#!/usr/bin/env node

import { readFileSync, writeFileSync } from "node:fs";
import { tmpdir } from "node:os";
import { join } from "node:path";
import { callDaemon } from "../lib/daemon-rpc.js";
import {
  COOKIE_DISMISS_SCRIPT,
  IFRAME_DISMISS_SCRIPT,
  PICK_SCRIPT,
} from "../lib/page-scripts.js";

function usage() {
  console.log("Usage: agent-web <command> [args]");
  console.log("");
  console.log("Commands:");
  console.log("  open <url> [--new]");
  console.log("  nav <url> [--new]");
  console.log("  snapshot [--role <role>] [--name <text>] [--text <text>] [--limit <n>]");
  console.log("           [--interactive|--headings|--links|--forms] [--context <n>]");
  console.log("           [--within <ref|selector>]");
  console.log("  click <ref|selector>");
  console.log("  fill <ref|selector> <value>");
  console.log("  get <property> <ref|selector>");
  console.log("  find role <role> <action> [--name <name>]");
  console.log("  list-tabs");
  console.log("  eval <javascript>");
  console.log("  cdp <Domain.method> [json-params]");
  console.log("  cdp browser <Domain.method> [json-params]");
  console.log("  cdp target <targetId> <Domain.method> [json-params]");
  console.log("  screenshot [path] [--full-page]");
  console.log("  close");
  console.log("  close-session");
  console.log("  pick <message>");
  console.log("  dismiss-cookies [--reject]");
  console.log("  status");
  console.log("  daemon-status");
}

function printValue(value) {
  if (value === "") return;
  console.log(value);
}

function normalizeUrl(value) {
  if (/^[a-zA-Z][a-zA-Z\d+.-]*:\/\//.test(value)) return value;
  if (/^(about|data|file|javascript|chrome|chrome-extension):/.test(value)) {
    return value;
  }
  return `https://${value}`;
}

function formatTable(rows, columns) {
  const widths = columns.map((column) =>
    Math.max(
      column.label.length,
      ...rows.map((row) => String(row[column.key] ?? "").length),
    ),
  );
  const formatRow = (row) =>
    columns
      .map((column, index) => String(row[column.key] ?? "").padEnd(widths[index]))
      .join("  ");

  console.log(formatRow(Object.fromEntries(columns.map((column) => [column.key, column.label]))));
  console.log(widths.map((width) => "-".repeat(width)).join("  "));
  for (const row of rows) console.log(formatRow(row));
}

function parseJsonParams(value) {
  if (value === undefined) return {};
  const text = value === "-" ? readFileSync(0, "utf8") : value;
  if (text.trim() === "") return {};
  try {
    return JSON.parse(text);
  } catch (e) {
    throw new Error(`invalid JSON params: ${e.message}`);
  }
}

function parseNonNegativeInteger(value, option) {
  if (!/^\d+$/.test(value || "")) {
    throw new Error(`${option} must be a non-negative integer`);
  }
  return Number(value);
}

function parseSnapshotArgs(args) {
  const params = {};

  for (let i = 0; i < args.length; i++) {
    const arg = args[i];
    const readValue = () => {
      const value = args[++i];
      if (value === undefined || value.startsWith("--")) {
        throw new Error(`${arg} requires a value`);
      }
      return value;
    };

    if (arg === "--role") {
      params.role = readValue();
    } else if (arg === "--name") {
      params.name = readValue();
    } else if (arg === "--text") {
      params.text = readValue();
    } else if (arg === "--limit") {
      params.limit = parseNonNegativeInteger(readValue(), "--limit");
    } else if (arg === "--context") {
      params.context = parseNonNegativeInteger(readValue(), "--context");
    } else if (arg === "--within") {
      params.within = readValue();
    } else if (arg === "--interactive") {
      params.preset = "interactive";
    } else if (arg === "--headings") {
      params.preset = "headings";
    } else if (arg === "--links") {
      params.preset = "links";
    } else if (arg === "--forms") {
      params.preset = "forms";
    } else {
      throw new Error(`Unknown snapshot argument: ${arg}`);
    }
  }

  return params;
}

async function main() {
  const [command, ...args] = process.argv.slice(2);

  if (!command || command === "--help" || command === "-h") {
    usage();
    process.exit(command ? 0 : 1);
  }

  if (command === "status") {
    const status = await callDaemon("status", {}, { timeout: 10000 });
    console.log(`ok: ${status.ok ? "yes" : "no"}`);
    console.log(`session: ${status.session}`);
    console.log(`tabs: ${status.tabs}`);
    if (status.activeUrl) console.log(`active: ${status.activeUrl}`);
    return;
  }

  if (command === "daemon-status") {
    const status = await callDaemon("daemonStatus", {}, { timeout: 10000 });
    console.log(`socket: ok`);
    console.log(`chrome: ${status.chromeUp ? "up" : "down"}${status.chromeConnected ? " (connected)" : ""}`);
    console.log(`chromePort: ${status.chromePort}`);
    console.log(`profile: ${status.profileDir}`);
    console.log(`caller: ${status.caller.id}`);
    console.log("");
    if (status.clients.length === 0) {
      console.log("No tracked clients");
    } else {
      formatTable(
        status.clients.map((client) => ({
          client: client.id,
          tabs: client.tabs,
          active: client.activeTargetId || "",
        })),
        [
          { key: "client", label: "CLIENT" },
          { key: "tabs", label: "TABS" },
          { key: "active", label: "ACTIVE_TARGET" },
        ],
      );
    }
    return;
  }

  if (command === "nav" || command === "open") {
    const rawUrl = args.find((arg) => !arg.startsWith("--"));
    const newTab = args.includes("--new");
    if (!rawUrl) {
      console.error("Usage: agent-web nav <url> [--new]");
      process.exit(1);
    }
    const url = normalizeUrl(rawUrl);
    await callDaemon("nav", { url, newTab });
    console.log(newTab ? "✓ Opened:" : "✓ Navigated to:", url);
    return;
  }

  if (command === "snapshot") {
    let params;
    try {
      params = parseSnapshotArgs(args);
    } catch (e) {
      console.error(`✗ ${e.message}`);
      console.error("Usage: agent-web snapshot [--role <role>] [--name <text>] [--text <text>] [--limit <n>]");
      console.error("                          [--interactive|--headings|--links|--forms] [--context <n>]");
      console.error("                          [--within <ref|selector>]");
      process.exit(1);
    }
    const result = await callDaemon("snapshot", params, { timeout: 30000 });
    printValue(result.text);
    return;
  }

  if (command === "click") {
    const locator = args[0];
    if (!locator) {
      console.error("Usage: agent-web click <ref|selector>");
      process.exit(1);
    }
    await callDaemon("click", { locator }, { timeout: 30000 });
    console.log(`✓ Clicked ${locator}`);
    return;
  }

  if (command === "fill") {
    const [locator, ...valueParts] = args;
    if (!locator || valueParts.length === 0) {
      console.error("Usage: agent-web fill <ref|selector> <value>");
      process.exit(1);
    }
    const value = valueParts.join(" ");
    await callDaemon("fill", { locator, value }, { timeout: 30000 });
    console.log(`✓ Filled ${locator}`);
    return;
  }

  if (command === "get") {
    const [property, locator] = args;
    if (!property || !locator) {
      console.error("Usage: agent-web get <property> <ref|selector>");
      process.exit(1);
    }
    const result = await callDaemon("get", { property, locator }, { timeout: 30000 });
    console.log(result.value);
    return;
  }

  if (command === "find") {
    const [kind, role, action, ...rest] = args;
    if (kind !== "role" || !role || !action) {
      console.error('Usage: agent-web find role <role> <action> [--name <name>]');
      process.exit(1);
    }
    const nameIndex = rest.indexOf("--name");
    const name = nameIndex === -1 ? null : rest.slice(nameIndex + 1).join(" ");
    const result = await callDaemon("find", { role, action, name }, { timeout: 30000 });
    if (action === "click") {
      console.log(`✓ Clicked ${result.ref}`);
    } else {
      console.log(result.ref);
    }
    return;
  }

  if (command === "list-tabs") {
    const result = await callDaemon("listTabs", {}, { timeout: 10000 });
    if (result.tabs.length === 0) {
      console.log("No tabs");
      return;
    }
    for (const tab of result.tabs) {
      const marker = tab.active ? "*" : " ";
      console.log(`${marker} ${tab.index}: ${tab.title || "(untitled)"} ${tab.url}`);
    }
    return;
  }

  if (command === "eval") {
    const code = args.join(" ");
    if (!code) {
      console.error("Usage: agent-web eval '<javascript>'");
      process.exit(1);
    }
    const result = await callDaemon("eval", { code });
    printValue(result.formatted);
    return;
  }

  if (command === "cdp") {
    let scope = "active";
    let targetId = null;
    let method;
    let jsonParams;

    if (args[0] === "browser") {
      scope = "browser";
      method = args[1];
      jsonParams = args[2];
    } else if (args[0] === "target") {
      scope = "target";
      targetId = args[1];
      method = args[2];
      jsonParams = args[3];
    } else {
      method = args[0];
      jsonParams = args[1];
    }

    if (!method || (scope === "target" && !targetId)) {
      console.error("Usage: agent-web cdp <Domain.method> [json-params]");
      console.error("       agent-web cdp browser <Domain.method> [json-params]");
      console.error("       agent-web cdp target <targetId> <Domain.method> [json-params]");
      process.exit(1);
    }

    const unknown = args.slice(
      scope === "browser" ? 3 : scope === "target" ? 4 : 2,
    );
    if (unknown.length > 0) {
      console.error(`✗ Unknown argument: ${unknown[0]}`);
      process.exit(1);
    }

    const result = await callDaemon(
      "rawCdp",
      {
        scope,
        targetId,
        method,
        params: parseJsonParams(jsonParams),
      },
      { timeout: 30000 },
    );
    console.log(JSON.stringify(result.result, null, 2));
    return;
  }

  if (command === "screenshot") {
    const filepathArg = args.find((arg) => !arg.startsWith("--"));
    const unknown = args.filter((arg) => arg !== "--full-page" && arg !== filepathArg);
    if (unknown.length > 0) {
      console.error(`✗ Unknown argument: ${unknown[0]}`);
      console.error("Usage: agent-web screenshot [path] [--full-page]");
      process.exit(1);
    }
    const result = await callDaemon("screenshot", { fullPage: args.includes("--full-page") });
    const filepath =
      filepathArg || join(tmpdir(), `screenshot-${new Date().toISOString().replace(/[:.]/g, "-")}.png`);
    writeFileSync(filepath, Buffer.from(result.data, "base64"));
    console.log(filepath);
    return;
  }

  if (command === "close") {
    const result = await callDaemon("close", {}, { timeout: 30000 });
    console.log(result.closed ? "✓ Closed current tab" : "○ No tab to close");
    return;
  }

  if (command === "close-session") {
    const result = await callDaemon("closeSession", {}, { timeout: 30000 });
    console.log(
      result.closed > 0
        ? `✓ Closed ${result.closed} session tab${result.closed === 1 ? "" : "s"}`
        : "○ No tabs to close",
    );
    return;
  }

  if (command === "pick") {
    const message = args.join(" ");
    if (!message) {
      console.error("Usage: agent-web pick <message>");
      process.exit(1);
    }
    const expression = `(${PICK_SCRIPT})(${JSON.stringify(message)})`;
    const result = await callDaemon("pick", { expression, timeout: 300000 }, { timeout: 310000 });
    printValue(result.formatted);
    return;
  }

  if (command === "dismiss-cookies") {
    const reject = args.includes("--reject");
    const unknown = args.filter((arg) => arg !== "--reject");
    if (unknown.length > 0) {
      console.error(`✗ Unknown argument: ${unknown[0]}`);
      console.error("Usage: agent-web dismiss-cookies [--reject]");
      process.exit(1);
    }
    const accept = !reject;
    const mode = reject ? "reject" : "accept";
    const result = await callDaemon(
      "dismissCookies",
      {
        mainExpression: `(${COOKIE_DISMISS_SCRIPT})(${accept})`,
        frameExpression: `(${IFRAME_DISMISS_SCRIPT})(${accept})`,
      },
      { timeout: 45000 },
    );
    if (result.clicked.length > 0) {
      console.log(`✓ Dismissed cookie dialog (${mode}): ${result.clicked.join(", ")}`);
    } else {
      console.log(`○ No cookie dialog found to ${mode}`);
    }
    return;
  }

  console.error(`✗ Unknown command: ${command}`);
  usage();
  process.exit(1);
}

try {
  await main();
} catch (e) {
  console.error("✗", e.message);
  process.exit(1);
}
